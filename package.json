{
  "name": "obsidian-stacktube",
  "version": "0.2.2",
  "description": "Sync StackTube YouTube knowledge notes into your Obsidian vault.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "youtube",
    "transcript",
    "notes",
    "pkm",
    "knowledge"
  ],
  "author": "unstackd",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.4.11",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  }
}
